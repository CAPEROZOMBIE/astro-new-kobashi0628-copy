---
// src/pages/news/[page].astro ニュース一覧ページ

import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Image from "astro/components/Image.astro";
import { Taniguchi_Date } from "../../library/taniguchi_date";

import { getKobashiNews } from "../../library/micro";


import { getKobashiCategories } from "../../library/micro"; //カテゴリーリストリンク
const Yamada_categoryList = await getKobashiCategories();

const currentPage = Number(Astro.params.page) || 1;
const limit = 8;
const offset = (currentPage - 1) * limit;

const Yamata_news = await getKobashiNews({
    limit,
    fields: ["title", "id", "category", "thumbnail","publishedAt"],
    offset,
});

// 総ページ数
const totalPages = Math.ceil(Yamata_news.totalCount / limit);

// ページ番号
const pageNumbers = Array.from({ length: totalPages }, (_, i) => i + 1).filter(
    (p) => {
        if (p === 1 || p === totalPages) return true;
        if (currentPage <= 3) return p <= 4;
        if (currentPage >= totalPages - 2) return p >= totalPages - 3;
        return Math.abs(p - currentPage) <= 1;
    },
);

// 第三段階へ ▼

// (1)全記事インポート

import { getKobashiAllNews } from "../../library/micro";

// (2)全記事取得

const allnews = await getKobashiAllNews({
    fields: ["publishedAt"],
});

// (3)アーカイブ（件数付き）

const archives: Record<string, number> = {};

allnews.forEach((item) => {
    if (!item.publishedAt) return;
    const d = new Date(item.publishedAt);
    const key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}`;
    archives[key] = (archives[key] || 0) + 1;
});

const archiveList = Object.entries(archives).sort((a, b) =>
    b[0].localeCompare(a[0]),
);

// 検索機能をつけよう

import SearchButton from "../../components/SearchButton";

---

<Layout title="ニュース一覧だお">
    <Header />
    <main>
        <h2>ニュース一覧</h2>
        <SearchButton client:load />
        <div>
            {
                Yamata_news.contents.map((item) => (
                    <div class="flex">
                        
                        <figure>
                            {item.thumbnail && (
                            
                                <Image
                                    src={item.thumbnail?.url}
                                    alt=""
                                    inferSize={true}
                                    fit="cover"
                                    position="top"
                                />
                            )}
                        </figure>
                        <div>
                            <div>{item.publishedAt && <p>{Taniguchi_Date(item.publishedAt)}</p>}</div>
                            <div><a href={`/news/detail/${item.id}`}>{item.title}</a>｜<a href={`/news/category/${item.category?.id}/1`}>{item.category?.name}</a></div>
                        </div>
                    </div>
                ))
            }
        </div>

        {/* 件数 */}
        <br />
        <hr />
        <br />
        <div class="pagination-count">
            {offset + 1}件 ~ {offset + Yamata_news.contents.length}件/ 全{
                Yamata_news.totalCount
            }件
        </div>

        <!-- ページネーション -->
        <div class="paginateion-wrap">
            {
                currentPage > 1 ? (
                    <a href={`/news/${currentPage - 1}`}>前のページ</a>
                ) : (
                    <span>前のページはないです</span>
                )
            }

            {
                pageNumbers.map((p, index) => (
                    <span>
                        {index > 0 && p - pageNumbers[index - 1] > 1 && (
                            <span>...</span>
                        )}
                        <a
                            href={`/news/${p}`}
                            class={
                                currentPage === p
                                    ? "page-number active"
                                    : "page-number"
                            }
                        >
                            {p}
                        </a>
                    </span>
                ))
            }

            {
                currentPage < totalPages ? (
                    <a href={`/news/${currentPage + 1}`}>次のページ</a>
                ) : (
                    <span>前のページはないです</span>
                )
            }
        </div>

        <!-- カテゴリーリストリンク -->
        <br />
        <hr />
        <br />
        <div>
            <ul>
                {
                    Yamada_categoryList.contents.map((item) => (
                        <li>
                            <a href={`/news/category/${item.id}/1`}>
                                {item.name}
                            </a>
                        </li>
                    ))
                }
            </ul>
        </div>

        <!-- (6)アーカイブ -->
        <br />
        <hr />
        <br />
        <ul>
            {
                archiveList.map(([month, count]) => {
                    const [y, m] = month.split("-");
                    return (
                        <li>
                            <a href={`/news/archive/${month}`}>
                                {y}年{m}月({count})
                            </a>
                        </li>
                    );
                })
            }
        </ul>
    </main>
    <Footer />
</Layout>

<style>
    
main {
    max-width: 800px;
    margin: 0 auto;
}

/* 中身 */
.flex {
    display: flex;
    gap: 20px;
    margin-top: 30px;
}

figure {
    width: 200px;
    margin: 0;
    /* background-color: antiquewhite; */
}

figure img {
    width: 100%;
    height: auto;
    aspect-ratio: 16/9;
    object-fit: cover;
    object-position: top;
}

.paginateion-wrap {
    margin-top: 10px;
    display: flex;
    gap: 20px;
    justify-content: center;
}

.yamata {
    color: black;
}

.page-number.active {
    color: red;
    font-weight: bold;
}

.pagination-count {
    margin-top: 20px;
    text-align: center;
}

</style>
